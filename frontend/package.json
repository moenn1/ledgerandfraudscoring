{
  "name": "ledgerforge-operator-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "node --no-warnings --experimental-strip-types ./scripts/lint.ts",
    "test": "node --no-warnings --experimental-strip-types --test src/*.test.ts",
    "test:watch": "node --no-warnings --experimental-strip-types --test --watch src/*.test.ts",
    "typecheck": "tsc -b --pretty false",
    "quality": "npm run lint && npm run test && npm run typecheck && npm run build",
    "build": "vite build",
    "preview": "vite preview --port 4173"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.3.4"
  }
}
