    {
      "name": "Payments",
      "item": [
        {
          "name": "POST /api/payments",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body && body.id) {",
                  "  pm.environment.set('paymentId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotencyKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payerAccountId\": \"payer-001\",\n  \"payeeAccountId\": \"payee-001\",\n  \"amountCents\": 12500,\n  \"currency\": \"{{currency}}\",\n  \"idempotencyKey\": \"{{idempotencyKey}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments",
              "host": [
